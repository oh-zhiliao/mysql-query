{
  "name": "zhiliao-plugin-mysql-query",
  "version": "1.0.0",
  "description": "MySQL query plugin for zhiliao",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src/ tests/ --max-warnings 0",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test:all": "npm run lint && npm run typecheck && npm run test",
    "preflight": "npm run test:all"
  },
  "keywords": [
    "zhiliao",
    "plugin",
    "mysql",
    "database"
  ],
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "mysql2": "^3.14.0"
  }
}
